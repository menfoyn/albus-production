@push('scripts')
<script>
/* ── Video Modal ─────────────────── */
function openVideoModal(){
    var m=document.getElementById('videoModal');
    if(!m)return;
    m.classList.add('is-open');
    document.body.style.overflow='hidden';
    document.getElementById('heroVideo').play();
}
function closeVideoModal(){
    var m=document.getElementById('videoModal');
    if(!m)return;
    m.classList.remove('is-open');
    document.body.style.overflow='';
    var v=document.getElementById('heroVideo');
    v.pause(); v.currentTime=0;
}

/* ── Lightbox ────────────────────── */
var galleryItems={!! json_encode(
    isset($galleryMedia) && $galleryMedia->count() ? $galleryMedia->map(function($m){
        return ['type'=>$m->type,'src'=>asset('storage/'.$m->file_path)];
    })->values() : []
) !!};
var currentSlide=0;

function openLightbox(i){
    currentSlide=i;
    renderSlide();
    document.getElementById('lightbox').classList.add('is-open');
    document.body.style.overflow='hidden';
}
function closeLightbox(){
    document.getElementById('lightbox').classList.remove('is-open');
    document.body.style.overflow='';
    document.querySelectorAll('#lbContent video').forEach(function(v){v.pause();});
}
function renderSlide(){
    var item=galleryItems[currentSlide];
    var box=document.getElementById('lbContent');
    if(item.type==='video'){
        box.innerHTML='<video controls autoplay style="max-width:90vw;max-height:85vh;border-radius:6px"><source src="'+item.src+'" type="video/mp4"></video>';
    }else{
        box.innerHTML='<img src="'+item.src+'" style="max-width:90vw;max-height:85vh;object-fit:contain;border-radius:6px">';
    }
    document.getElementById('lbCounter').textContent=(currentSlide+1)+' / '+galleryItems.length;
}
function nextSlide(){
    currentSlide=(currentSlide+1)%galleryItems.length;
    renderSlide();
}
function prevSlide(){
    currentSlide=(currentSlide-1+galleryItems.length)%galleryItems.length;
    renderSlide();
}
document.addEventListener('keydown',function(e){
    var lb=document.getElementById('lightbox');
    if(lb&&lb.classList.contains('is-open')){
        if(e.key==='Escape')closeLightbox();
        if(e.key==='ArrowRight')nextSlide();
        if(e.key==='ArrowLeft')prevSlide();
    }
    var vm=document.getElementById('videoModal');
    if(vm&&vm.classList.contains('is-open')&&e.key==='Escape')closeVideoModal();
});
</script>
@endpush
